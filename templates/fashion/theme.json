{
  "name": "Fashion Laboratory",
  "theme": {
    "palette": {
      "primary": "#FFFFFF",
      "secondary": "#050505",
      "accent": "#000000",
      "text": {
        "main": "#000000",
        "muted": "#888888",
        "contrast": "#FFFFFF"
      },
      "ui": {
        "border": "#EEEEEE",
        "hover": "#F9F9F9",
        "shadow": "none"
      }
    },
    "typography": {
      "heading": {
        "font": "var(--font-geist)",
        "style": "font-bold tracking-tighter uppercase"
      },
      "body": {
        "font": "var(--font-inter)",
        "style": "font-normal leading-relaxed"
      }
    },
    "spacing": {
      "page_pt": "pt-48",
      "container": "max-w-[1440px]",
      "gutter": "px-6 md:px-12",
      "card_gap": "gap-12"
    },
    "interaction": {
      "button": "bg-black text-white hover:bg-neutral-800 transition-all font-bold uppercase tracking-[0.4em] rounded-none",
      "card_hover": "grayscale-[0.5] hover:grayscale-0 transition-all duration-[2s]"
    }
  }
}
