{
  "name": "Exhibition Musei Vaticani",
  "theme": {
    "palette": {
      "primary": "#0F0F0F",
      "secondary": "#F9F6F0",
      "accent": "#F9F6F0",
      "text": {
        "main": "#F9F6F0",
        "muted": "rgba(249, 246, 240, 0.4)",
        "contrast": "#0F0F0F"
      },
      "ui": {
        "border": "rgba(249, 246, 240, 0.1)",
        "hover": "#F9F6F0",
        "shadow": "0 30px 60px rgba(0,0,0,0.5)"
      }
    },
    "typography": {
      "heading": {
        "font": "var(--font-playfair)",
        "style": "font-medium tracking-tighter uppercase"
      },
      "body": {
        "font": "var(--font-inter)",
        "style": "font-light tracking-widest leading-relaxed"
      }
    },
    "spacing": {
      "page_pt": "pt-20",
      "container": "max-w-7xl",
      "gutter": "px-6",
      "card_gap": "gap-24"
    },
    "interaction": {
      "button": "border border-[#F9F6F0]/30 text-[#F9F6F0] hover:bg-[#F9F6F0] hover:text-[#0F0F0F] transition-all font-bold uppercase tracking-[0.4em]",
      "card_hover": "scale-100 brightness-100 transition-all duration-[1.5s]"
    }
  }
}
