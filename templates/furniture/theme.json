{
  "name": "vinuspread",
  "theme": {
    "palette": {
      "primary": "#FFFFFF",
      "secondary": "#1A1A1A",
      "accent": "#0071E3",
      "text": {
        "main": "#1D1D1F",
        "muted": "#6E6E73",
        "contrast": "#FFFFFF"
      },
      "ui": {
        "border": "rgba(0,0,0,0.01)",
        "hover": "#F5F5F7",
        "shadow": "0 20px 50px rgba(0,0,0,0.05)"
      }
    },
    "typography": {
      "heading": {
        "font": "Outfit, sans-serif",
        "style": "uppercase font-bold tracking-tighter"
      },
      "body": {
        "font": "Inter, sans-serif",
        "style": "leading-relaxed"
      }
    },
    "spacing": {
      "page_pt": "pt-32",
      "container": "max-w-[1440px]",
      "gutter": "px-6 md:px-12",
      "card_gap": "gap-1"
    },
    "interaction": {
      "button": "bg-black text-white hover:bg-zinc-800 transition-all rounded-full font-bold uppercase tracking-widest",
      "card_hover": "scale-[1.02] transition-transform duration-700"
    }
  }
}
