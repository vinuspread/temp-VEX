{
  "name": "Studio Corporate",
  "theme": {
    "palette": {
      "primary": "#FFFFFF",
      "secondary": "#090B19",
      "accent": "#1A1A1A",
      "text": {
        "main": "#1A1A1A",
        "muted": "#6E6E73",
        "contrast": "#FFFFFF"
      },
      "ui": {
        "border": "rgba(0,0,0,0.05)",
        "hover": "#F4F4F7",
        "shadow": "0 20px 80px rgba(0,0,0,0.05)"
      }
    },
    "typography": {
      "heading": {
        "font": "var(--font-outfit)",
        "style": "font-semibold tracking-[-0.03em] uppercase"
      },
      "body": {
        "font": "var(--font-inter)",
        "style": "font-normal leading-relaxed"
      }
    },
    "spacing": {
      "page_pt": "pt-48",
      "container": "max-w-full",
      "gutter": "px-[64px]",
      "card_gap": "gap-[48px]"
    },
    "interaction": {
      "button": "bg-black text-white hover:bg-neutral-800 transition-all font-bold uppercase tracking-[3px] rounded-none",
      "card_hover": "translate-x-4 transition-transform duration-700"
    }
  }
}
