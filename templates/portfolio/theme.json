{
  "name": "Portfolio Brutalist",
  "theme": {
    "palette": {
      "primary": "#FFFFFF",
      "secondary": "#000000",
      "accent": "#ED008C",
      "text": {
        "main": "#000000",
        "muted": "#707070",
        "contrast": "#FFFFFF"
      },
      "ui": {
        "border": "rgba(0,0,0,0.1)",
        "hover": "#F5F5F5",
        "shadow": "0 10px 30px rgba(0,0,0,0.05)"
      }
    },
    "typography": {
      "heading": {
        "font": "var(--font-inter)",
        "style": "font-black tracking-tighter uppercase italic"
      },
      "body": {
        "font": "var(--font-inter)",
        "style": "font-medium"
      }
    },
    "spacing": {
      "page_pt": "pt-48",
      "container": "max-w-[1440px]",
      "gutter": "px-6",
      "card_gap": "gap-24"
    },
    "interaction": {
      "button": "border border-[#ED008C] text-[#ED008C] hover:bg-[#ED008C] hover:text-black transition-all font-black uppercase italic tracking-tight",
      "card_hover": "scale-105 transition-transform duration-1000"
    }
  }
}
