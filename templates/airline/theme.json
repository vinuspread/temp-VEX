{
  "name": "Airline Premium",
  "theme": {
    "palette": {
      "primary": "#000000",
      "secondary": "#FFFFFF",
      "accent": "#FFFFFF",
      "text": {
        "main": "#FFFFFF",
        "muted": "#A3A3A3",
        "contrast": "#000000"
      },
      "ui": {
        "border": "rgba(255,255,255,0.1)",
        "hover": "#FFFFFF",
        "shadow": "0 0 40px rgba(255,255,255,0.05)"
      }
    },
    "typography": {
      "heading": {
        "font": "var(--font-playfair)",
        "style": "font-black tracking-tighter uppercase"
      },
      "body": {
        "font": "var(--font-inter)",
        "style": "font-bold tracking-[0.2em] uppercase"
      }
    },
    "spacing": {
      "page_pt": "pt-0",
      "container": "max-w-full",
      "gutter": "px-12",
      "card_gap": "gap-20"
    },
    "interaction": {
      "button": "border border-white/20 text-white hover:bg-white hover:text-black transition-all font-bold uppercase tracking-[0.4em]",
      "card_hover": "scale-105 transition-all duration-700"
    }
  }
}
