{
  "name": "Sneaker Brutalist",
  "theme": {
    "palette": {
      "primary": "#FFFFFF",
      "secondary": "#000000",
      "accent": "#FF3B30",
      "text": {
        "main": "#000000",
        "muted": "#707070",
        "contrast": "#FFFFFF"
      },
      "ui": {
        "border": "#000000",
        "hover": "#F0F0F0",
        "shadow": "none"
      }
    },
    "typography": {
      "heading": {
        "font": "var(--font-inter)",
        "style": "font-black tracking-tighter uppercase italic"
      },
      "body": {
        "font": "var(--font-inter)",
        "style": "font-medium tracking-tight"
      }
    },
    "spacing": {
      "page_pt": "pt-40",
      "container": "max-w-[1440px]",
      "gutter": "px-6 md:px-12",
      "card_gap": "gap-8"
    },
    "interaction": {
      "button": "bg-black text-white hover:bg-neutral-800 transition-all font-black uppercase tracking-widest italic rounded-none",
      "card_hover": "scale-[1.05] grayscale-0 transition-all duration-700"
    }
  }
}
