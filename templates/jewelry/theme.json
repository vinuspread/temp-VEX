{
  "name": "Jewelry Luxury",
  "theme": {
    "palette": {
      "primary": "#F9F6F0",
      "secondary": "#171717",
      "accent": "#70C5BB",
      "text": {
        "main": "#171717",
        "muted": "#737373",
        "contrast": "#FFFFFF"
      },
      "ui": {
        "border": "rgba(0,0,0,0.1)",
        "hover": "#FFFFFF",
        "shadow": "0 10px 30px rgba(0,0,0,0.02)"
      }
    },
    "typography": {
      "heading": {
        "font": "var(--font-playfair)",
        "style": "font-normal tracking-[0.2em] uppercase"
      },
      "body": {
        "font": "var(--font-inter)",
        "style": "font-light leading-relaxed"
      }
    },
    "spacing": {
      "page_pt": "pt-48",
      "container": "max-w-[1440px]",
      "gutter": "px-6 md:px-12",
      "card_gap": "gap-12"
    },
    "interaction": {
      "button": "bg-[#171717] text-white hover:bg-[#70C5BB] transition-all font-bold uppercase tracking-[0.4em] shadow-xl",
      "card_hover": "scale-105 grayscale-0 transition-all duration-[2s]"
    }
  }
}
